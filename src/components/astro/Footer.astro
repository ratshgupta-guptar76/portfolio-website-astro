---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/[0.06] bg-[#050506]">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-16 py-10 flex flex-col sm:flex-row justify-between gap-3">
    <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-[#706d65]">
      &copy; {year} Ratish Gupta
    </span>
    <div class="flex items-center gap-6">
      <a
        href="https://github.com/ratishgupta"
        rel="noopener noreferrer"
        target="_blank"
        class="font-mono text-[10px] tracking-[0.2em] uppercase text-[#706d65] hover:text-[#ebe6dd] transition-colors"
      >
        Github
      </a>
      <a
        href="https://www.linkedin.com/in/ratishgupta"
        rel="noopener noreferrer"
        target="_blank"
        class="font-mono text-[10px] tracking-[0.2em] uppercase text-[#706d65] hover:text-[#ebe6dd] transition-colors"
      >
        LinkedIn
      </a>
      <a
        href="mailto:ratishgupta2005@gmail.com"
        class="font-mono text-[10px] tracking-[0.2em] uppercase text-[#706d65] hover:text-[#ebe6dd] transition-colors"
      >
        Email
      </a>
      <a
        href="/resume.pdf"
        class="font-mono text-[10px] tracking-[0.2em] uppercase text-[#706d65] hover:text-[#ebe6dd] transition-colors"
      >
        Resume
      </a>
    </div>
  </div>
</footer>
