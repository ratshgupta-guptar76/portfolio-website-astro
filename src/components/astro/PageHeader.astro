---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
}

const { eyebrow, title, lede } = Astro.props;
---

<header class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-16 pt-32 md:pt-40 pb-16 md:pb-24">
  {eyebrow && (
    <p class="font-mono text-[10px] tracking-[0.4em] uppercase text-muted-foreground mb-8">
      {eyebrow}
    </p>
  )}

  <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-primary leading-[1.05] tracking-tight max-w-4xl">
    {title}
  </h1>

  {lede && (
    <p class="mt-8 font-sans text-base md:text-lg text-foreground/70 max-w-2xl leading-relaxed">
      {lede}
    </p>
  )}
</header>
