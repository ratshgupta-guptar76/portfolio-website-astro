---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PageHeader } from '@/app/components/ui/PageHeader';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const dateFmt = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' });
const fmtDate = (d?: Date) => (d ? dateFmt.format(d) : '');
---

<BaseLayout title={`${data.title} | Ratish Gupta`} description={data.summary}>
  <PageHeader client:load kicker={`Project · ${data.category}`} title={data.title} lede={data.summary} back={{ to: '/projects', label: 'All Projects' }} />

  <section class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-16 pb-24 md:pb-40">
    <div class="grid grid-cols-1 lg:grid-cols-[14rem_1fr] gap-12 lg:gap-20">
      <aside class="lg:sticky lg:top-28 lg:self-start">
        <div class="flex flex-row lg:flex-col flex-wrap gap-x-10 gap-y-7 pb-6 border-b lg:border-b-0 border-white/[0.06]">
          <div class="flex flex-col gap-1.5"><span class="font-mono text-[9px] uppercase tracking-[0.3em] text-[#5a5750]">Date</span><div class="font-sans text-[13px] text-[#ebe6dd]/80">{fmtDate(data.date)}</div></div>
          {data.updated ? <div class="flex flex-col gap-1.5"><span class="font-mono text-[9px] uppercase tracking-[0.3em] text-[#5a5750]">Updated</span><div class="font-sans text-[13px] text-[#ebe6dd]/80">{fmtDate(data.updated)}</div></div> : null}
          <div class="flex flex-col gap-1.5"><span class="font-mono text-[9px] uppercase tracking-[0.3em] text-[#5a5750]">Status</span><div class="font-sans text-[13px] text-[#ebe6dd]/80">{data.status}</div></div>
          <div class="flex flex-col gap-1.5"><span class="font-mono text-[9px] uppercase tracking-[0.3em] text-[#5a5750]">Stack</span><ul class="flex flex-col gap-1 font-mono text-[12px] text-[#ebe6dd]/70">{data.stack.map((s) => <li>{s}</li>)}</ul></div>
          <div class="flex flex-col gap-1.5"><span class="font-mono text-[9px] uppercase tracking-[0.3em] text-[#5a5750]">Tags</span><div class="flex flex-wrap gap-1.5">{data.tags.map((tag) => <span class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#706d65] border border-white/[0.08] px-2.5 py-0.5">{tag}</span>)}</div></div>
          {data.source ? <div class="flex flex-col gap-1.5"><span class="font-mono text-[9px] uppercase tracking-[0.3em] text-[#5a5750]">Source</span><a href={data.source.startsWith('http') ? data.source : `https://${data.source}`} class="font-mono text-[12px] text-[#ebe6dd]/70 hover:text-[#ebe6dd] transition-colors break-all">{data.source}</a></div> : null}
          {data.paper ? <div class="flex flex-col gap-1.5"><span class="font-mono text-[9px] uppercase tracking-[0.3em] text-[#5a5750]">Paper</span><span class="font-mono text-[12px] text-[#ebe6dd]/70">{data.paper}</span></div> : null}
        </div>
      </aside>

      <article class="max-w-[68ch] prose-mdx">
        {data.results.length > 0 && (
          <div class="border border-white/[0.08] mb-10 overflow-x-auto">
            <table class="w-full font-mono text-[13px]" style="font-variant-numeric: tabular-nums;">
              <tbody>
                {data.results.map((result) => (
                  <tr class="border-b border-white/[0.05] last:border-b-0">
                    <th class="text-left font-normal py-3 px-4 text-[#706d65] uppercase text-[10px] tracking-[0.18em] w-1/2">{result.label}</th>
                    <td class="py-3 px-4 text-[#ebe6dd]/85 text-right">{result.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        <div class="prose-body">
          <Content />
        </div>

        {data.synthesis.length > 0 && (
          <>
            <h2 class="font-sans text-[22px] text-[#ebe6dd] tracking-[-0.01em] pt-10 mt-2 mb-5 border-t border-white/[0.08]">Synthesis &amp; timing</h2>
            <div class="border border-white/[0.08] mb-10 overflow-x-auto">
              <table class="w-full font-mono text-[13px]" style="font-variant-numeric: tabular-nums;">
                <thead>
                  <tr class="border-b border-white/[0.08]">
                    <th class="text-left font-normal py-3 px-4 text-[#706d65] uppercase text-[10px] tracking-[0.18em]">Stage</th>
                    <th class="text-right font-normal py-3 px-4 text-[#706d65] uppercase text-[10px] tracking-[0.18em]">Frequency</th>
                    <th class="text-right font-normal py-3 px-4 text-[#706d65] uppercase text-[10px] tracking-[0.18em]">Slack</th>
                    <th class="text-right font-normal py-3 px-4 text-[#706d65] uppercase text-[10px] tracking-[0.18em]">Area</th>
                  </tr>
                </thead>
                <tbody>
                  {data.synthesis.map((row) => (
                    <tr class="border-b border-white/[0.04] last:border-b-0">
                      <td class="py-3 px-4 text-[#ebe6dd]/85">{row.stage}</td>
                      <td class="py-3 px-4 text-right text-[#ebe6dd]/70">{row.frequency}</td>
                      <td class="py-3 px-4 text-right text-[#ebe6dd]/70">{row.slack}</td>
                      <td class="py-3 px-4 text-right text-[#ebe6dd]/70">{row.area}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        )}

        <div class="pt-8 border-t border-white/[0.08] flex items-center justify-between">
          <a href="/projects" class="font-mono text-[10px] uppercase tracking-[0.25em] text-[#706d65] hover:text-[#ebe6dd] transition-colors">← Index</a>
          <a href="/contact" class="font-mono text-[10px] uppercase tracking-[0.25em] text-[#706d65] hover:text-[#ebe6dd] transition-colors">Discuss this project →</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .prose-body {
    font-family: var(--font-serif);
    font-size: 17px;
    color: #cfc9bf;
    line-height: 1.75;
  }
  .prose-body > p:first-child {
    font-size: 18px;
    color: #ebe6dd;
    opacity: 0.85;
    margin-bottom: 2.5rem;
  }
  .prose-body p { margin-bottom: 1.5rem; }
  .prose-body h2 {
    font-family: var(--font-sans);
    font-size: 22px;
    color: #ebe6dd;
    letter-spacing: -0.01em;
    padding-top: 2.5rem;
    margin-top: 0.5rem;
    margin-bottom: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .prose-body h3 {
    font-family: var(--font-sans);
    font-size: 17px;
    color: #ebe6dd;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-body pre {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(0, 0, 0, 0.3) !important;
    padding: 1.25rem;
    margin: 1.75rem 0;
    overflow-x: auto;
    font-size: 12.5px;
    line-height: 1.65;
  }
  .prose-body code {
    font-family: var(--font-mono);
    font-size: 0.92em;
  }
  .prose-body :not(pre) > code {
    background: rgba(255, 255, 255, 0.04);
    padding: 0.1rem 0.35rem;
    color: #ebe6dd;
  }
  .prose-body figure {
    margin: 0.5rem 0 2rem;
  }
  .prose-body figcaption {
    text-align: center;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: #706d65;
  }
  .prose-body blockquote {
    margin: 1.75rem 0;
    padding-left: 1.25rem;
    border-left: 1px solid rgba(255, 255, 255, 0.15);
    color: #a8a39a;
    font-style: italic;
  }
  .prose-body em { color: #ebe6dd; opacity: 0.9; }
  .prose-body strong { color: #ebe6dd; font-weight: 500; }
  .prose-body .katex-display {
    margin: 1.5rem 0;
    overflow-x: auto;
    overflow-y: hidden;
  }
</style>
