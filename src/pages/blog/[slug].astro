---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PageHeader } from '../../app/components/ui/PageHeader';
import { getCollection, render } from 'astro:content';
import ScrollableTable from '../../components/mdx/ScrollableTable.astro';
import Link from '../../components/mdx/Link.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const dateFmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: '2-digit', year: 'numeric' });

const titleCase = (s: string) => s.split('-').map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
const primaryTag = data.tags[0] ? titleCase(data.tags[0]) : 'Note';
const kicker = data.tags[0] ? `Note · ${primaryTag}` : 'Note';
---

<BaseLayout title={`${data.title} | Ratish Gupta`} description={data.lede}>
  <PageHeader client:load kicker={kicker} title={data.title} lede={data.lede} back={{ to: '/blog', label: 'All Notes' }} />

  <section class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-16 pb-24 md:pb-40">
    <article class="max-w-[68ch]">
      <div class="flex flex-wrap items-center gap-4 pb-6 mb-12 border-b border-white/[0.08]">
        <span class="font-mono text-[11px] tracking-[0.1em] text-[#9a958c]">{dateFmt.format(data.date)}</span>
        {data.updated ? <><span class="text-[#3f3d38]">·</span><span class="font-mono text-[11px] tracking-[0.1em] text-[#9a958c]">Updated {dateFmt.format(data.updated)}</span></> : null}
        <div class="flex flex-wrap gap-1.5 ml-auto">
          {data.tags.map((tag) => (
            <span class="font-mono text-[9px] uppercase tracking-[0.18em] text-[#9a958c] border border-white/[0.08] px-2.5 py-0.5">{tag}</span>
          ))}
        </div>
      </div>

      <div class="prose-body">
        <Content components={{ table: ScrollableTable, a: Link }} />
      </div>

      {data.references.length > 0 && (
        <div class="mt-16 pt-8 border-t border-white/[0.08]">
          <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#9a958c] mb-4 block">References</span>
          <ol class="font-sans text-[13px] text-[#8a8680] leading-[1.7] space-y-2 list-decimal pl-5">
            {data.references.map((reference) => <li>{reference}</li>)}
          </ol>
        </div>
      )}

      <div class="mt-16 pt-8 border-t border-white/[0.08] flex items-center justify-between">
        <a href="/blog" class="font-mono text-[10px] uppercase tracking-[0.25em] text-[#9a958c] hover:text-[#ebe6dd] transition-colors">← All Notes</a>
        <a href="/contact" class="font-mono text-[10px] uppercase tracking-[0.25em] text-[#9a958c] hover:text-[#ebe6dd] transition-colors">Get in touch →</a>
      </div>
    </article>
  </section>
</BaseLayout>

<style is:global>
  .prose-body {
    font-family: var(--font-serif);
    font-size: 17px;
    color: #cfc9bf;
    line-height: 1.75;
  }
  .prose-body p { margin-bottom: 1.5rem; }
  .prose-body h2 {
    font-family: var(--font-sans);
    font-size: 22px;
    color: #ebe6dd;
    letter-spacing: -0.01em;
    padding-top: 2.5rem;
    margin-top: 0.5rem;
    margin-bottom: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .prose-body pre {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(0, 0, 0, 0.3) !important;
    padding: 1.25rem;
    margin: 1.75rem 0;
    overflow-x: auto;
    font-size: 12.5px;
    line-height: 1.65;
  }
  .prose-body code { font-family: var(--font-mono); font-size: 0.92em; }
  .prose-body :not(pre) > code {
    background: rgba(255, 255, 255, 0.04);
    padding: 0.1rem 0.35rem;
    color: #ebe6dd;
  }
  .prose-body em { color: #ebe6dd; opacity: 0.9; }
  .prose-body strong { color: #ebe6dd; font-weight: 500; }
  .prose-body blockquote {
    margin: 1.75rem 0;
    padding-left: 1.25rem;
    border-left: 1px solid rgba(255, 255, 255, 0.15);
    color: #a8a39a;
    font-style: italic;
  }
  .prose-body .katex-display {
    margin: 1.5rem 0;
    overflow-x: auto;
    overflow-y: hidden;
  }
</style>
