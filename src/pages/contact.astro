---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PageHeader } from '@/app/components/ui/PageHeader';
---

<BaseLayout title="Contact | Ratish Gupta" description="Contact details and availability.">
  <PageHeader client:load kicker="Contact" title="Get in touch" lede="The fastest way to reach me is email. I read everything; I do not always reply quickly." back={{ to: '/', label: 'Back to Home' }} />
  <section class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-16 pb-20">
    <div class="max-w-[68ch]">
      <dl class="grid grid-cols-1 md:grid-cols-[10rem_1fr] gap-y-6 gap-x-10 border-t border-white/[0.08] pt-10">
        <div class="contents"><dt class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#706d65] pt-1">Email</dt><dd class="font-mono text-[14px] text-[#ebe6dd]/85 break-all">ratishgupta2005@gmail.com</dd></div>
        <div class="contents"><dt class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#706d65] pt-1">GitHub</dt><dd class="font-mono text-[14px] text-[#ebe6dd]/85 break-all"><a href="https://github.com/ratishgupta" class="hover:text-white transition-colors border-b border-white/0 hover:border-white/30">github.com/ratishgupta</a></dd></div>
        <div class="contents"><dt class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#706d65] pt-1">LinkedIn</dt><dd class="font-mono text-[14px] text-[#ebe6dd]/85 break-all"><a href="https://linkedin.com/in/ratishgupta" class="hover:text-white transition-colors border-b border-white/0 hover:border-white/30">linkedin.com/in/ratishgupta</a></dd></div>
        <div class="contents"><dt class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#706d65] pt-1">Scholar</dt><dd class="font-mono text-[14px] text-[#ebe6dd]/85 break-all"><a href="https://scholar.google.com" class="hover:text-white transition-colors border-b border-white/0 hover:border-white/30">scholar.google.com/citations?user=…</a></dd></div>
      </dl>

      <p class="mt-16 pt-8 border-t border-white/[0.08] font-serif text-[16px] text-[#a8a39a] leading-[1.75]">Currently open to internship and full-time discussions for <span class="text-[#ebe6dd]">Summer 2026</span> in digital design, verification, or accelerator architecture. Recruiters are welcome; please mention the role and team in the first message.</p>
    </div>
  </section>
</BaseLayout>
