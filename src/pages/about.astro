---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PageHeader } from '../app/components/ui/PageHeader';

const disciplines = [
  { label: 'HDL & RTL',      detail: 'SystemVerilog, Verilog, FSM design, datapath & control logic' },
  { label: 'Verification',   detail: 'cocotb, Verilator, ModelSim, QuestaSim, timing analysis, pipelining' },
  { label: 'FPGA',           detail: 'Xilinx Artix-7 (Vivado), Altera DE1-SoC (Quartus Prime), GTKWave' },
  { label: 'DSP & Embedded', detail: 'Polyphase FIR, PLL/CDR, RDS, ARM Cortex-M, UART / I²C / GPIO, multithreaded systems' },
  { label: 'Programming',    detail: 'C / C++17, Python (NumPy, signal processing), Java, Tcl scripting, Make' },
  { label: 'Lab & Debug',    detail: 'Oscilloscope, logic analyser, LTspice, PSpice, signal-integrity analysis' },
];
---

<BaseLayout
  title="About — Ratish Gupta"
  description="Computer Engineering student at McMaster focused on RTL design, FPGA verification, and ML hardware acceleration — background, disciplines, and current work."
>
  <PageHeader client:load kicker="About" title="Ratish Gupta" back={{ to: '/', label: 'Back to Home' }} />

  <section class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-16 pb-24 grid md:grid-cols-2 gap-12 border-t border-white/[0.06] pt-12">
    <div class="space-y-6">
      <p class="font-sans text-base md:text-lg text-foreground/80 leading-relaxed">
        I'm a Computer Engineering student at McMaster (B.Eng., 2023&nbsp;– 2027).
        My focus is RTL design, FPGA verification, and ML hardware acceleration.
        The main thing I'm working on right now is a compute-in-memory
        transformer accelerator on FPGA. The first milestone, an 8&times;8 INT8
        systolic MAC array, closes timing at 100&nbsp;MHz with 64 DSP48E1
        slices on Artix-7.
      </p>
      <p class="font-sans text-base text-foreground/70 leading-relaxed">
        My RTL is written in SystemVerilog and verified with cocotb plus
        Verilator. I run synthesis through Vivado or Quartus depending on the
        board. Software side, I write C++17 and Python. The most recent of
        those is a real-time multithreaded FM SDR receiver that decodes mono,
        stereo, and RDS on a Raspberry Pi. Last summer I interned at the Bank
        of Montreal as a software developer, mostly on backend microservices
        and the testing around them.
      </p>
      <p class="font-sans text-base text-foreground/70 leading-relaxed">
        Honours: Dean's Honour List (2024), Engineering International Scholar
        Award, Faculty of Engineering Award of Excellence, Dean's Global
        Distinction. I went to IEEE ISSCC 2026 in San Francisco for the AI
        accelerator and compute-in-memory sessions.
      </p>
      <div class="flex items-center gap-4 pt-4">
        <a
          href="/pdfs/resume/resume.pdf"
          class="font-mono text-[10px] tracking-[0.25em] uppercase border border-white/15 px-6 py-3 text-primary hover:border-white/40 transition-colors"
        >
          Download resume ↓
        </a>
        <a
          href="/contact"
          class="font-mono text-[10px] tracking-[0.25em] uppercase text-muted-foreground hover:text-primary transition-colors"
        >
          Get in touch →
        </a>
      </div>
    </div>

    <div class="border border-white/[0.06] aspect-[4/5] flex items-center justify-center">
      <span class="font-mono text-[10px] tracking-[0.3em] uppercase text-muted-foreground">
        Portrait — placeholder
      </span>
    </div>
  </section>

  <section class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-16 pb-32 border-t border-white/[0.06] pt-12">
    <h2 class="font-mono text-[10px] tracking-[0.4em] uppercase text-muted-foreground font-normal mb-8">
      Disciplines
    </h2>
    <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
      {disciplines.map((d) => (
        <div class="flex justify-between items-baseline border-b border-white/[0.06] pb-4 gap-6">
          <dt class="font-serif text-xl text-primary">{d.label}</dt>
          <dd class="font-sans text-sm text-foreground/65 text-right">{d.detail}</dd>
        </div>
      ))}
    </dl>
  </section>
</BaseLayout>
